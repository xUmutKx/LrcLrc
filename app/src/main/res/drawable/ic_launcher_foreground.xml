<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Simple key icon, replacing the old music-note + "triangle flag" mark.
        Drawn entirely inside the adaptive-icon safe zone (the centered 66x66
        area, i.e. roughly x:21-87 / y:21-87) so it isn't cropped on any
        launcher mask shape (circle, squircle, rounded square, etc).
        Bow (the round part you hold) + shaft + two teeth at the tip.
    -->

    <!-- Bow: a ring, drawn as a thick circular stroke -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C9BBFF"
        android:strokeWidth="7"
        android:pathData="M30,40 A12,12 0 1,0 30.01,40"/>

    <!-- Shaft -->
    <path
        android:fillColor="#C9BBFF"
        android:pathData="M38,40 L78,40 L78,47 L71,47 L71,54 L64,54 L64,47 L52,47 L52,40 Z"/>

</vector>
